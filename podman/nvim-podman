#!/usr/bin/env bash
# Launch Neovim (kickstart.nvim) inside a Debian-slim container using Podman/Docker.
# This script:
# - Persists Neovim config, plugins, and cache on the host
# - Automatically starts a host PyLSP server from a .venv if available
# - Exposes PyLSP host/port to the container via environment variables
# - Cleans up pylsp on exit

set -euo pipefail  # strict mode: exit on error, undefined var, or failed pipe

# -------------------------------------------------------------------
# Detect Podman binary
# -------------------------------------------------------------------
PODMAN_BIN="$(command -v podman || true)"
if [ -z "$PODMAN_BIN" ]; then
  echo "podman not found" >&2
  exit 1
fi

# Container image to use (can override via $IMAGE)
IMAGE="${IMAGE:-localhost/nvim-podman:0.2.2}"

# -------------------------------------------------------------------
# Prepare host persistence directories
# -------------------------------------------------------------------
# These should match the directories defined in container Dockerfile!
mkdir -p "$HOME/.config/nvim" \
         "$HOME/.local/share/nvim" \
         "$HOME/.cache/nvim"

# -------------------------------------------------------------------
# Resolve input arguments (files/folders)
# -------------------------------------------------------------------
if [ $# -gt 0 ]; then
  args=()
  for path in "$@"; do
    # Create the file if it doesn't exist
    if [ ! -e "$path" ]; then
      touch "$path"
    fi
    # Resolve absolute path and store only the basename for container
    abs_path="$(realpath "$path")"
    args+=( "$(basename "$abs_path")" )
  done
else
  # Default to current directory
  args=(".")
fi

# -------------------------------------------------------------------
# Determine working directory for mounts
# -------------------------------------------------------------------
if [ -z "${1-}" ]; then
  # No argument: leave WORKDIR empty
  abs_path=""
  WORKDIR=""
else
  path="$1"
  abs_path="$(realpath -e "$path")"
  WORKDIR="$(dirname "$abs_path")"
fi

# Make Podman mount and working directory options dynamic
if [ -n "$WORKDIR" ]; then
  WORKDIR_OPTIONS=(-v "$WORKDIR:$WORKDIR" -w "$WORKDIR")
else
  WORKDIR_OPTIONS=()
fi

# -------------------------------------------------------------------
# Display server environment
# -------------------------------------------------------------------
# Detect Wayland or X11 session to forward display correctly
if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
  : "${WAYLAND_DISPLAY:=wayland-0}"  # fallback to wayland-0
  DISPLAY_VAR="WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
elif [ "${XDG_SESSION_TYPE:-}" = "x11" ]; then
  DISPLAY_VAR="DISPLAY=$DISPLAY"
else
  DISPLAY_VAR=""
fi

DISPLAY_ARGS=()
if [ -n "${DISPLAY_VAR:-}" ]; then
  DISPLAY_ARGS+=( -e "$DISPLAY_VAR" )
fi

# -------------------------------------------------------------------
# Host PyLSP detection + launch
# -------------------------------------------------------------------
PYLSP_HOST="127.0.0.1"

# Store pylsp PID and port in /tmp
# Use a hash of the WORKDIR to make files unique per project
PROJECT_HASH="$(echo "${WORKDIR:-$PWD}" | md5sum | awk '{print $1}')"
PYLSP_PORT_FILE="/tmp/.pylsp-port-$PROJECT_HASH"
PYLSP_PID_FILE="/tmp/.pylsp-pid-$PROJECT_HASH"

# Locate a local .venv by walking up from WORKDIR
find_venv() {
  local dir="${WORKDIR:-$PWD}"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.venv" ]; then
      echo "$dir/.venv"
      return
    fi
    dir="$(dirname "$dir")"
  done
}

VENV_PATH="$(find_venv || true)"

# Function to launch PyLSP from the host .venv
launch_pylsp() {
  local venv="$1"

  # Ensure pylsp exists in this venv
  if [ ! -x "$venv/bin/pylsp" ]; then
    echo "No pylsp executable found in $venv"
    return
  fi

  # Reuse existing server if it is alive
  if [ -f "$PYLSP_PID_FILE" ] && kill -0 "$(cat "$PYLSP_PID_FILE")" 2>/dev/null; then
    if [ -f "$PYLSP_PORT_FILE" ]; then
      PYLSP_PORT="$(cat "$PYLSP_PORT_FILE")"
      echo "Reusing existing pylsp on port $PYLSP_PORT"
      return
    fi
  fi

  # Pick a free random port for this project
  PYLSP_PORT="$(shuf -i 20000-40000 -n 1)"
  echo "Launching pylsp from $venv on port $PYLSP_PORT"

  # Launch pylsp in background, logging to /tmp
  "$venv/bin/pylsp" --tcp --host "$PYLSP_HOST" --port "$PYLSP_PORT" \
    > /tmp/pylsp.log 2>&1 &

  PYLSP_PID=$!  # PID of the background pylsp process
  echo "$PYLSP_PID" > "$PYLSP_PID_FILE"
  echo "$PYLSP_PORT" > "$PYLSP_PORT_FILE"

  # Ensure pylsp is killed when this launcher exits
  trap "kill $PYLSP_PID 2>/dev/null || true" EXIT
}

# Default port if no .venv is found
# Intended for system-level PyLSP installations
PYLSP_PORT=2087

# Launch host PyLSP if a .venv exists
if [ -n "${VENV_PATH:-}" ]; then
  launch_pylsp "$VENV_PATH"
fi

# -------------------------------------------------------------------
# Launch Neovim container
# -------------------------------------------------------------------
"$PODMAN_BIN" run --rm -it \
  --network=host \
  -e TERM=xterm-256color \
  -e PYLSP_HOST="$PYLSP_HOST" \
  -e PYLSP_PORT="$PYLSP_PORT" \
  -e XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
  "${DISPLAY_ARGS[@]}" \
  "${WORKDIR_OPTIONS[@]}" \
  -v "$XDG_RUNTIME_DIR:$XDG_RUNTIME_DIR" \
  -v "$HOME/.config/nvim:/work/.config/nvim" \
  -v "$HOME/.gradle:/root/.gradle" \
  "$IMAGE" "${args[@]}"
