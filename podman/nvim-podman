#!/usr/bin/env bash
# Launch Neovim (kickstart.nvim) inside a Debian-slim container using Docker.
# - Persists config/plugins/cache on the HOST via XDG_* dirs

set -euo pipefail

PODMAN_BIN="$(command -v podman || true)"
if [ -z "$PODMAN_BIN" ]; then
  echo "podman not found" >&2
  exit 1
fi

IMAGE="${IMAGE:-localhost/nvim-podman:0.1.1}"

# Host persistence dirs needs to match setup Dockerfile
mkdir -p "$HOME/.config/nvim" \
         "$HOME/.local/share/nvim" \
         "$HOME/.cache/nvim"

# Resolve basenames/file names from argument
if [ $# -gt 0 ]; then
  args=()
  for path in "$@"; do
    # Create file if missing
    if [ ! -e "$path" ]; then
      touch "$path"
    fi
    # Resolve absolute path
    abs_path="$(realpath "$path")"
    args+=( "$(basename "$abs_path")" )
  done
else
  args=(".")
fi

# Resolve abosulte path and get workdir
if [ -z "${1-}" ]; then
  # No argument -> unset variables and do not mount or set workdir
  abs_path=""
  WORKDIR=""
else
  path="$1"
  abs_path="$(realpath -e "$path")"
  WORKDIR="$(dirname "$abs_path")"
fi

# Compose podman volume and working directory options dynamically
if [ -n "$WORKDIR" ]; then
  WORKDIR_OPTIONS=(-v "$WORKDIR:$WORKDIR" -w "$WORKDIR")
else
  WORKDIR_OPTIONS=()
fi

# Resolve display compositor
if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
  # use the existing WAYLAND_DISPLAY, fallback to wayland-0 if missing
  : "${WAYLAND_DISPLAY:=wayland-0}"
  DISPLAY_VAR="WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
elif [ "${XDG_SESSION_TYPE:-}" = "x11" ]; then
  DISPLAY_VAR="DISPLAY=$DISPLAY"
else
  DISPLAY_VAR=""
fi

DISPLAY_ARGS=()
if [ -n "${DISPLAY_VAR:-}" ]; then
  DISPLAY_ARGS+=( -e "$DISPLAY_VAR" )
fi

exec "$PODMAN_BIN" run --rm -it \
  --network=host \
  -e TERM=xterm-256color \
  -e PYLSP_HOST=127.0.0.1 -e PYLSP_PORT=2087 \
  -e XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
  "${DISPLAY_ARGS[@]}" \
  "${WORKDIR_OPTIONS[@]}" \
  -v "$XDG_RUNTIME_DIR:$XDG_RUNTIME_DIR" \
  -v "$HOME/.config/nvim:/work/.config/nvim" \
  "$IMAGE" "${args[@]}"
