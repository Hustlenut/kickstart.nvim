#!/usr/bin/env bash
# Launch Neovim (kickstart.nvim) inside a Debian-slim container using Docker.
# - Persists config/plugins/cache on the HOST via XDG_* dirs

set -euo pipefail

IMAGE="${IMAGE:-localhost/nvim-podman:latest}"
NVIM_APPNAME="${NVIM_APPNAME:-nvim-podman}"

# Host persistence dirs
mkdir -p "$HOME/.config/$NVIM_APPNAME" \
         "$HOME/.local/share/$NVIM_APPNAME" \
         "$HOME/.cache/$NVIM_APPNAME"

# Bootstrap kickstart.nvim on host if missing
if [ ! -f "$HOME/.config/$NVIM_APPNAME/init.lua" ] && [ ! -d "$HOME/.config/$NVIM_APPNAME/.git" ]; then
  git clone https://github.com/Hustlenut/kickstart.nvim.git "$HOME/.config/$NVIM_APPNAME"
fi

# Resolve basenames from argument
if [ $# -gt 0 ]; then
  args=()
  for path in "$@"; do
    # Step 1: Create file if missing (do NOT rely on realpath yet)
    if [ ! -e "$path" ]; then
      touch "$path"
    fi
    # Step 2: Now resolve absolute path safely
    abs_path="$(realpath "$path")"
    args+=( "$(basename "$abs_path")" )
  done
else
  args=(".")
fi

# Resolve abosulte path and get workdir
if [ -z "${1-}" ]; then
  # No argument: unset variables and do not mount or set workdir
  abs_path=""
  WORKDIR=""
else
  path="$1"
  abs_path="$(realpath -e "$path")"
  WORKDIR="$(dirname "$abs_path")"
fi

# Compose podman volume and working directory options dynamically
if [ -n "$WORKDIR" ]; then
  WORKDIR_OPTIONS=(-v "$WORKDIR:$WORKDIR" -w "$WORKDIR")
else
  WORKDIR_OPTIONS=()
fi

# Resolve display compositor
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
  DISPLAY_VAR="WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
elif [ "$XDG_SESSION_TYPE" = "x11" ]; then
  DISPLAY_VAR="DISPLAY=$DISPLAY"
else
  # Fallback or unknown
  echo "XDG session type not found"
  DISPLAY_VAR=""
fi

exec podman run --rm -it \
  --network=host \
  --userns=keep-id \
  -u "$(id -u):$(id -g)" \
  -e TERM=xterm-256color \
  -e NVIM_APPNAME="$NVIM_APPNAME" \
  -e XDG_CONFIG_HOME=/nvim/config \
  -e XDG_DATA_HOME=/nvim/data \
  -e XDG_CACHE_HOME=/nvim/cache \
  -e PYLSP_HOST=127.0.0.1 -e PYLSP_PORT=2087 \
  -e DISPLAY_VAR \
  -e XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
  -v "$XDG_RUNTIME_DIR:$XDG_RUNTIME_DIR" \
  "${WORKDIR_OPTIONS[@]}" \
  -v "$HOME/.config/$NVIM_APPNAME":/nvim/config/$NVIM_APPNAME \
  -v "$HOME/.local/share/$NVIM_APPNAME":/nvim/data/$NVIM_APPNAME \
  -v "$HOME/.cache/$NVIM_APPNAME":/nvim/cache/$NVIM_APPNAME \
  "$IMAGE" "${args[@]}"
