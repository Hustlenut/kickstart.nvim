# Dockerfile.user - Creates host username dynamically
FROM localhost/nvim-podman:base

# build-user.sh makes these dynamic
ARG USERNAME=neo
ARG USER_ID=1000
ARG GROUP_ID=1000

RUN groupadd -g ${GROUP_ID} ${USERNAME} && \
    useradd -m -u ${USER_ID} -g ${GROUP_ID} \
            -d /home/${USERNAME} -s /bin/bash ${USERNAME}

# Give host user ownership of /work
RUN chown -R ${USER_ID}:${GROUP_ID} /work

# Fix toolchains permissions (readable by everyone)
RUN chmod -R 755 /opt/nvim /opt/node /opt/go 2>/dev/null || true

USER ${USERNAME}
ENV HOME=/home/${USERNAME}
ENV USER=${USERNAME}
WORKDIR /home/${USERNAME}/workspace

HEALTHCHECK CMD nvim --headless -c 'checkhealth' -c 'qa!' || exit 1
